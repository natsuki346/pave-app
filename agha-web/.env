# AGHA Environment Variables

# ==========================================
# 1. Google AI Studio (Gemini) API Key
# ==========================================
# 取得方法:
# 1. https://aistudio.google.com/app/apikey にアクセス
# 2. [Create API Key] ボタンをクリック
# 3. 生成されたキーをコピーして以下に貼り付け
GEMINI_API_KEY="AIzaSy..."

# ==========================================
# 2. Google Cloud / Calendar API Credentials
# ==========================================
# 取得方法:
# 1. Google Cloud Console (https://console.cloud.google.com/) にアクセス
# 2. 新しいプロジェクトを作成 (例: agha-backend)
# 3. [APIとサービス] > [ライブラリ] から「Google Calendar API」を検索して有効化
# 4. [APIとサービス] > [認証情報] から「サービス アカウントを作成」
# 5. 作成したサービスアカウントのキー（JSON）を生成してダウンロード
# 6. JSON内の `client_email` と `private_key` の値を以下に設定
GOOGLE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv... (改行を\nに置換した1行の文字列)...\n-----END PRIVATE KEY-----\n"

# 7. 対象のカレンダーID (通常は自分のGoogleアカウントのメルアド)
GOOGLE_CALENDAR_ID="your.email@gmail.com"

# ※カレンダーの「設定と共有」画面で、上記の GOOGLE_CLIENT_EMAIL に対して
# 「予定の変更権限」を付与して共有設定を行ってください。

# ==========================================
# 3. Webhook / Security (Optional for Local)
# ==========================================
# Cloud Functionsデプロイ後、エンドポイントを保護するための秘密鍵
AGHA_WEBHOOK_SECRET="generate-a-random-string-here"
